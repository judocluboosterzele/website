---
import { Image } from "astro:assets";
import { render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { resolveContentImage } from "../lib/contentImages";
import "../styles/info.css";

interface Props {
  page: any;
  heroImage?: any;
  images?: any[];
}

const { page, images } = Astro.props;

const folder = page?.id
  ? page.id.split("/").slice(0, -1).join("/")
  : "general";

const resolvedHeroImage = resolveContentImage(page?.data?.heroImage, folder);
const resolvedImages = (images ?? []).map((img: any) => ({
  src: resolveContentImage(img.src ?? img, folder),
  alt: img.alt || "",
})).filter((img: any) => img.src !== null);

const { Content } = await render(page);

const formatDate = (d: string) =>
  new Intl.DateTimeFormat("nl-BE", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(d));
---

<Layout title={page.data.title} description={page.data.description}>
  <Navbar />

  <main class="page-type-info">
    {
      resolvedHeroImage && (
        <section class="page-hero">
          <div class="container">
            <div class="hero-image-container">
              <Image
                src={resolvedHeroImage}
                alt={page.data.heroImageAlt || page.data.title}
                width={800}
                height={450}
                format="webp"
                quality={80}
              />
            </div>
          </div>
        </section>
      )
    }

    <section class="page-content">
      <div class="container">
        <article class="content-article content-article--info">
          <h1>{page.data.title}</h1>
          {page.data.date && <h4>{formatDate(page.data.date)}</h4>}
          <Content />

          {
            resolvedImages && resolvedImages.length > 0 && (
              <div class="content-images">
                {resolvedImages.map((img: any) => (
                  <div class="image-wrapper">
                    <Image
                      src={img.src}
                      alt={img.alt}
                      width={800}
                      height={600}
                      format="webp"
                      quality={85}
                    />
                  </div>
                ))}
              </div>
            )
          }

          {
            page.data.facebookLink && (
              <div class="facebook-link-container">
                <a
                  href={page.data.facebookLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="facebook-link"
                >
                  Bekijk op Facebook →
                </a>
              </div>
            )
          }
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
