---
import { getCollection } from "astro:content";
import InfoPage from "../components/InfoPage.astro";
import LesgeversPage from "../components/LesgeversPage.astro";
import VerslagenPage from "../components/VerslagenPage.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((page) => ({
    params: { slug: page.id },
    props: page,
  }));
}

const page = Astro.props;
const pageType = page.data.type || "info";

const heroImage = page.data.heroImage ?? null;

// Load images from frontmatter if they exist
let contentImages: any[] = [];
if (page.data.images) {
  contentImages = page.data.images;
}
---

{
  pageType === "lesgevers" && (
    <LesgeversPage page={page} heroImage={heroImage} />
  )
}

{
  pageType === "info" && (
    <InfoPage page={page} heroImage={heroImage} images={contentImages} />
  )
}

{pageType === "verslagen" && <VerslagenPage page={page} />}

{
  !["lesgevers", "info", "verslagen"].includes(pageType) && (
    <InfoPage page={page} heroImage={heroImage} images={contentImages} />
  )
}
